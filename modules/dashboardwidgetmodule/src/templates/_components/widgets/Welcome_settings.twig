{% import "_includes/forms" as forms %}

{% do view.registerAssetBundle("modules\\dashboardwidgetmodule\\assetbundles\\dashboardwidgetmodule\\DashboardWidgetModuleAsset") %}

{{ forms.textArea({
    label: 'Message',
    instructions: 'Enter a message here.',
    id: 'message',
    name: 'message',
    value: widget['message']})
}}

{{ forms.textField({
    label: 'Iframe',
    instructions: 'Enter a Iframe.',
    id: 'iframe',
    name: 'iframe',
    value: widget['iframe']})
}}
