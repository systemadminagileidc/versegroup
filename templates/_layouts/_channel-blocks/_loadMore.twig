<section class="grid-row {{ rowSpace }} {{ colour }}  {{ paddingTop }} {{ paddingBottom }}">
    <div class="grid {{ rowLayout }} {{ width }} {{ gridGap }} {{ blockSize ?? '' }}"

    {{ sprig('_layouts/_sprig-components/_load-more',{
        'limit': limit,
        'popup': popup,
        'order': order.value,
        'section': section,
        'buttonStyle': buttonStyle.value,
        'offset': 0,
        'popup': popup,
        'imageCrop': imageCrop.value,
        'showPostDate': showPostDate,
    }) }}
    </div>
</section>
